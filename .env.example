# GitHub OAuth Configuration
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Session Configuration
SESSION_SECRET=your_session_secret_here_change_this
SESSION_COOKIE_MAX_AGE=86400000 # 24 hours in milliseconds

# Server Configuration
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173 # Vite dev server

# Database (Optional - for caching and user preferences)
DATABASE_URL=postgresql://user:password@localhost:5432/github_monitor

# Redis (Optional - for session store and caching)
REDIS_URL=redis://localhost:6379

# GitHub API Rate Limiting
GITHUB_RATE_LIMIT_WINDOW_MS=60000 # 1 minute
GITHUB_RATE_LIMIT_MAX_REQUESTS=60 # 60 requests per minute

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:3000/api
VITE_WS_URL=ws://localhost:3000